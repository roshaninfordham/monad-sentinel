{
  "name": "monad-sentinel",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "pnpm --filter @monad-sentinel/web dev",
    "build": "pnpm --filter @monad-sentinel/web build",
    "lint": "pnpm --filter @monad-sentinel/web lint",
    "test": "pnpm --filter @monad-sentinel/shared test && pnpm --filter @monad-sentinel/chain-agent test",
    "contracts:build": "forge build --root packages/contracts",
    "contracts:test": "forge test --root packages/contracts",
    "contracts:deploy": "forge script script/Deploy.s.sol --root packages/contracts --rpc-url $MONAD_RPC_URL --broadcast",
    "agent:dev": "pnpm --filter @monad-sentinel/chain-agent dev",
    "sentinel:init": "tsx scripts/sentinel.ts init",
    "sentinel:dev": "tsx scripts/sentinel.ts dev",
    "sentinel:launch": "tsx scripts/sentinel.ts launch",
    "sentinel:ship": "tsx scripts/sentinel.ts ship",
    "sentinel:reset": "tsx scripts/sentinel.ts reset",
    "sentinel:verify": "tsx scripts/sentinel.ts verify"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "chalk": "^5.6.2",
    "dotenv": "^16.6.1",
    "execa": "^9.6.1",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
